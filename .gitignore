# Sensitive config — never commit
config/api_keys.yaml
config/api_keys.yml
.env
.env.*
*.secret
secrets.yaml

# Project workspace data — user-specific, not source
projects/videos/
pipeline/projects/
global_registry.json
competitor_intelligence/channels/*/videos/

# Large binary assets — manage separately
global_assets/sounds/
global_assets/characters/**/*.mp3

# Non-project planning/audit docs — keep locally, do not publish to GitHub
# Rule: only source code, configs, and docs/pipeline/ architecture files belong on GitHub.
# Development plans, integration analyses, workflow guides, and audit reports stay local.
docs/pipeline/integration/
pipeline/audit/
_AUDIT_TEMP.md
.planning/

# Root-level development/planning docs
REMOTION_INTEGRATION.md
DAVINCI_WORKFLOW.md
KOKORO_INTEGRATION.md
PRODUCTION_PIPELINE.md

