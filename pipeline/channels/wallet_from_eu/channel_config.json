{
  "channel_id": "wallet_from_eu",
  "channel_name": "Wallet from the EU",
  "niche": "personal finance / economics",
  "target_platform": "youtube_longform",
  "target_audience": "working-class viewers 20-45, no finance background, curious about money",
  "language": "english",
  "narrative_style": {
    "tone": "cynical-but-smart, sarcastic, educational, never neutral",
    "storytelling_pattern": "announcement→mechanism→promises_vs_reality→historical_parallel→personal_impact→uncomfortable_truth→comment_bait",
    "hook_preferences": [
      "stat_shock",
      "myth_bust",
      "news_hook",
      "curiosity_gap",
      "fear_loss"
    ],
    "reward_type": "knowledge+mechanism_reveal",
    "language_style": "plain english, no jargon without translation, short punches after long setups, numbers always with comparison and emotional translation",
    "personality": "ex-Wall Street analyst trapped in a stand-up comic body — authority + mockery + clarity"
  },
  "visual_style": {
    "animation_type": "2d_explainer",
    "color_palette": [
      "#FFFFFF",
      "#000000",
      "#FF6B00",
      "#4CAF50",
      "#2196F3",
      "#FF4444"
    ],
    "character_system": {
      "yellow": "worker / viewer avatar",
      "blue": "narrator / expert / official",
      "green": "wealthy / positive outcome",
      "red": "villain / bad actor",
      "purple": "rich woman with flower accessory",
      "orange": "government official",
      "gray": "crowd / generic mass"
    },
    "character_style": "flat stickman, round head, oval body, two dot eyes, color-coded",
    "scene_density": "moderate — max 4 elements per frame",
    "text_style": "bold sans-serif, high contrast",
    "visual_references": [
      "casually_finance"
    ]
  },
  "frame_rules": {
    "mode": "dynamic",
    "avg_cut_interval_sec": 4.0,
    "change_triggers": [
      "new concept introduced in narration",
      "punchline lands — pause after",
      "number revealed — show it visually",
      "scene location changes in story",
      "emotional tone shifts",
      "every 12-15 seconds minimum (reset point)"
    ],
    "appearance_animation": true,
    "reset_point_interval_sec": 12
  },
  "audio_style": {
    "music_mood": "low_tension_cinematic",
    "beat_sync": false,
    "tts_speed": 1.0,
    "pause_between_scenes_sec": 0.4
  },
  "prompt_style": {
    "image_prompt_prefix": "flat 2d animation, white background, bold black outlines, simple round stickman characters, clean vector style",
    "image_negative_prompt": "realistic, photo, 3d render, complex background, text, watermark, detailed faces, gradient",
    "character_description": "simple round-headed stickman figures, color-coded by role per character_system",
    "object_style": "flat vector, clean lines, high contrast, minimal detail, single color fills"
  },
  "registry_system": {
    "scenario_registry_sheets": [
      "overview",
      "structure",
      "chapters",
      "key_data",
      "emotion_map",
      "production",
      "assets",
      "performance"
    ],
    "master_registry_sheets": [
      "all_episodes",
      "production_pipeline",
      "hooks_analysis",
      "content_themes",
      "performance_summary"
    ],
    "asset_registry_sheets": [
      "asset_registry_summary",
      "G-CHR-001_crowd_characters",
      "G-OBJ-001_money"
    ],
    "master_project": "_master",
    "competitors_project": "competitors"
  },
  "uniqueness_system": {
    "aus_formula": "min(1.0, max(0, 1-(total_uses-1)*0.10) + min(0.25, (variant_count-1)*0.05))",
    "fes_formula": "AUS * max(0, 1 - uses_in_this_video * 0.15)",
    "vuc_formula": "sum(FES_i * weight_i) / sum(weight_i)",
    "weight_scale": {
      "background": 0.5,
      "object": 1.0,
      "character": 1.5,
      "main_element": 2.0
    },
    "vuc_thresholds": {
      "excellent": 0.85,
      "good": 0.7,
      "warning": 0.55
    },
    "exempt_roles": [
      "BASE",
      "LORA"
    ],
    "overuse_thresholds": {
      "global_warn": 10,
      "project_warn": 5
    }
  },
  "workflow": {
    "session_start": [
      "pipeline_get_channel_config",
      "pipeline_get_channel_skill SCENARIO_WRITER",
      "pipeline_get_channel_skill IMAGE_PROMPTS",
      "pipeline_get_channel_skill FRAME_RULES",
      "pipeline_get_channel_skill HOOK_ENGINE"
    ],
    "before_scenario": [
      "pipeline_get_project_registry(_master, sheet=all_episodes) — review what exists",
      "pipeline_get_global_registry(sheet=asset_registry_summary) — check AUS scores",
      "pipeline_query_registry(_master, sheet=hooks_analysis) — review hook performance"
    ],
    "after_scenario": [
      "pipeline_set_video_structure — record Hook Engine data",
      "pipeline_add_emotion_map — record emotional arc",
      "pipeline_add_registry_row(sheet=key_data) — record all facts with verification status",
      "pipeline_update_registry(_master production_pipeline) — update status to done"
    ],
    "before_scene_layout": [
      "pipeline_get_global_registry(sheet=asset_registry_summary) — check AUS",
      "pipeline_search_assets — find needed elements by semantic/emotion tags",
      "If AUS < 0.70 for needed asset — create variant or generate new"
    ],
    "after_render": [
      "Compute FES for each asset in this video",
      "Compute VUC for entire video",
      "pipeline_add_registry_row(performance sheet, metric=video_uniqueness_coefficient)",
      "Update global asset_registry total_uses for all rendered assets"
    ],
    "after_publish": [
      "pipeline_import_platform_stats — load YouTube data",
      "Cross-reference retention curve with emotion_map chapters",
      "pipeline_add_registry_row(sheet=insights) — record findings",
      "pipeline_update_registry(_master performance_summary) — update all metrics"
    ]
  },
  "skills_path": "channels/wallet_from_eu/skills/",
  "created_from_competitors": [
    "casually_finance"
  ],
  "episodes": {
    "ep01_tariffs": {
      "title": "The Tax You're Paying Without Knowing It",
      "status": "script_ready"
    },
    "ep02_debt": {
      "title": "Who Does America Owe $36 Trillion To?",
      "status": "script_ready"
    }
  },
  "created_at": "2026-05-21",
  "version": "2.0",
  "language_rules": {
    "mandatory_language": "english",
    "prohibition": "Russian language is strictly prohibited in all project output. All text — scenarios, registry entries, notes, analysis, insights, asset descriptions, chapter titles, skill files — must be written in English. No exceptions regardless of user input language."
  }
}